# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://devpulse:devpulse@localhost:26772/devpulse

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:41356

# ─── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:17642/api/v1/auth/github/callback

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── Encryption ────────────────────────────────────────────────────────────────
# 32-byte key (64 hex chars) for AES-256-GCM encryption of GitHub tokens at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── API ───────────────────────────────────────────────────────────────────────
PORT=17642
ALLOWED_ORIGINS=http://localhost:38929

# ─── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:17642
NEXT_PUBLIC_APP_URL=http://localhost:38929
NEXTAUTH_URL=http://localhost:38929
NEXTAUTH_SECRET=change-this-to-a-long-random-string-in-production

# ─── App URLs (used in Stripe redirects + welcome emails) ──────────────────────
APP_URL=http://localhost:38929

# ─── Stripe (leave empty to disable billing — UI shows "coming soon") ──────────
# Get test keys at: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret from `stripe listen --forward-to localhost:17642/api/v1/stripe/webhook`
STRIPE_WEBHOOK_SECRET=
# Price IDs created in Stripe dashboard for each plan/interval combo
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_TEAM_MONTHLY_PRICE_ID=
STRIPE_TEAM_YEARLY_PRICE_ID=

# ─── Resend (email) ────────────────────────────────────────────────────────────
# Get API key at: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=hello@reflog.app
